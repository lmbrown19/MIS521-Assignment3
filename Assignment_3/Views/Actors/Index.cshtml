@model IEnumerable<Assignment_3.Models.Actor>

@{
    ViewData["Title"] = "Actors";
}

<h1>Actors</h1>
<div class="page-actions">
    <a asp-action="Create" class="btn btn-primary ui-button">Create New</a>
</div>
<div class="table-responsive">
<table class="table table-bordered ui-widget-content">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.gender)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.age)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IMDBlink)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.mediaLink)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.gender)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.age)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IMDBlink)
            </td>
            <td>
                @if (!string.IsNullOrWhiteSpace(item.mediaLink))
                {
                    <img src="@item.mediaLink" alt="@item.name" class="img-thumbnail" style="max-height:150px;" />
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
</div>
